APP_NAME="UPA TIK"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=imbalanced_data_system
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

IP_GEOLOCATION_BASE_URL=https://ipwho.is
IP_GEOLOCATION_CACHE_TTL=2592000

# ML Detection Configuration
ML_DETECTION_ENABLED=true
ML_DETECTION_SCHEDULE=hourly
ML_DETECTION_SCHEDULE_TIME=13:00
ML_DETECTION_SCHEDULE_TIMEZONE=Asia/Jakarta
ML_API_KEY=change_me_for_ml_flask
ML_FLASK_URL=https://yourdomain.com/api/ml
ML_DETECTION_TIMEOUT=60

UPA_TIK_API_ENABLED=false
UPA_TIK_API_BASE_URL=http://103.245.38.142
UPA_TIK_API_ENDPOINT=/datasets
UPA_TIK_API_TOKEN=
UPA_TIK_API_TIMEOUT=30
UPA_TIK_API_SYSTEM_USER_EMAIL=

VPS_CSV_ENABLED=false
VPS_CSV_SCHEDULE=daily_at
VPS_CSV_SCHEDULE_TIME=12:55
VPS_CSV_SCHEDULE_TIMEZONE=Asia/Jakarta
VPS_CSV_MAX_FILES=10
VPS_CSV_SYSTEM_USER_EMAIL=
VPS_CSV_DELETE_AFTER_PROCESSING=false
VPS_CSV_CONNECT_TIMEOUT=15
VPS_CSV_TIMEOUT=120
VPS_CSV_HAS_HEADER=true
VPS_CSV_DELIMITER=,
VPS_CSV_KEEP_LOCAL_COPY=false

VPS_HOST=103.245.38.142
VPS_PORT=22
VPS_USERNAME=tsabit
VPS_SOURCE_DIR=/var/www/syslog-datasets
VPS_TARGET_DIR=/var/www/alfin
VPS_BASE_URL=http://103.245.38.142/datasets
VPS_PRIVATE_KEY_PATH=
VPS_PRIVATE_KEY=

VITE_APP_NAME="${APP_NAME}"
